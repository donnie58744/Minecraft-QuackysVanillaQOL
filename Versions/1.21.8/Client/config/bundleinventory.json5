{
	// How many rows will be visible in Bundle inventory
	"bundleInventoryVisibleRows": 6,
	// Should play sounds when player is interacting with Bundle via inventory
	"shouldPlayBundleInventorySounds": true,
	// Should highlight open Bundle by rendering it differently
	"indicateOpenBundle": true,
	// Show armor & second hand slots in Bundle inventory
	"showEquipmentSlotsInBundleInventory": false,
	// Do client-side checks of bundle occupancy on item insertion
	"clientSideItemInsertionChecks": true
}